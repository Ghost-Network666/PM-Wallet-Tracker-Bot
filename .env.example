# Discord Bot Token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application Client ID (required for command registration)
DISCORD_CLIENT_ID=your_discord_application_client_id

# Channel ID where tracking notifications are sent (required)
DISCORD_CHANNEL_ID=123456789012345678

# Optional: Guild ID for faster guild-only command registration during dev
# DISCORD_GUILD_ID=123456789012345678

# Polling interval in milliseconds (default: 60000 = 60 seconds)
TRACKING_INTERVAL=60000

# Max number of positions/trades/activity items to fetch per wallet per poll
MAX_FETCH_ITEMS=100
